# ════════════════════════════════════════════════════════════════
# FUTURE MAGNUS BUSINESS OS — PRODUCTION ENVIRONMENT VARIABLES
# ════════════════════════════════════════════════════════════════
# Copy this file to backend/.env and fill in your values.
#
# Hostinger Managed Node.js: Set these in hPanel > Node.js > Environment Variables
# Hostinger VPS:              Copy to backend/.env
# ════════════════════════════════════════════════════════════════

# ─── Application ───
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://yourdomain.com

# ─── MongoDB (Required — Use MongoDB Atlas) ───
# Hostinger does NOT host MongoDB. Create a free cluster at https://www.mongodb.com/atlas
# Replace <username>, <password>, <cluster>, <dbname>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT Secrets (Required — generate strong random strings) ───
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-hex-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis (Optional — for BullMQ queues; skip if not using) ───
# Hostinger doesn't provide Redis. Use Upstash (free tier) or Redis Cloud.
REDIS_URL=redis://default:<password>@<host>:<port>

# ─── Email SMTP (Required for password resets & notifications) ───
# Options: SendGrid, Mailgun, Brevo (Sendinblue), or Hostinger Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com

# ─── Razorpay (Required for payment processing) ───
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── AWS S3 (Optional — for backups & file storage) ───
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=magnus-backups

# ─── Rate Limiting (All optional; defaults apply if omitted) ───
#
# Auth endpoints (login, register, forgot-password, reset-password):
#   IP-based limit (default: 10 requests per 15 min)
AUTH_RATE_LIMIT_IP_MAX=10
AUTH_RATE_LIMIT_IP_WINDOW_MS=900000
#   Account-based limit with exponential backoff (default: 5 base max, factor 2)
AUTH_RATE_LIMIT_ACCOUNT_BASE_MAX=5
AUTH_RATE_LIMIT_ACCOUNT_BACKOFF_FACTOR=2
AUTH_RATE_LIMIT_ACCOUNT_WINDOW_MS=900000
#
# Public endpoints (health, contact — default: 30 req / 15 min)
PUBLIC_RATE_LIMIT_MAX=30
PUBLIC_RATE_LIMIT_WINDOW_MS=900000
#
# Authenticated API endpoints (default: 100 req / 15 min)
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW_MS=900000

# ─── Super Admin (Used on first seed only) ───
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=ChangeThis@123
SUPER_ADMIN_PHONE=+919999999999

# ─── Frontend (Vite) — Optional; defaults to same origin in production ───
# Only set these if the backend API is on a DIFFERENT domain than the frontend.
# On Hostinger Managed Node.js or VPS with Nginx proxy, leave these unset.
VITE_API_URL=https://yourdomain.com
VITE_SOCKET_URL=wss://yourdomain.com
