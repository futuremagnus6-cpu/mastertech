{
  "name": "future-magnus-bos-backend",
  "version": "2.0.0",
  "description": "Future Magnus Business OS — Production-Ready SaaS Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "seed:super-admin": "node scripts/seedSuperAdmin.js",
    "kill:port": "node -e \"const{execSync}=require('child_process');try{const p=execSync('netstat -ano|findstr :5000|findstr LISTENING',{encoding:'utf8'}).trim().split(/\\s+/).pop();execSync('taskkill /F /PID '+p);console.log('Killed process '+p+' on port 5000')}catch(e){console.log('Port 5000 is free')}\"",
    "predev": "npm run kill:port",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit --verbose",
    "test:watch": "cross-env NODE_ENV=test jest --watch --detectOpenHandles",
    "lint": "eslint src/"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsbarcode": "^3.11.6",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^6.9.7",
    "otplib": "^12.0.1",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.6",
    "sharp": "^0.33.1",
    "socket.io": "^4.7.2",
    "speakeasy": "^2.0.0",
    "uuid": "^14.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
